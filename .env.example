# PostgreSQL Connection (required)
PGHOST=localhost
PGPORT=5432
PGDATABASE=xracing
PGUSER=your_user
PGPASSWORD=your_password

# Environment: DEV, QA, or PROD (enables SSL for QA/PROD)
APP_ENV=DEV

# Server port (optional, defaults to 3000)
PORT=3000

# Google Analytics 4 (optional)
# Property ID in format: properties/123456789
GA4_PROPERTY_ID=

# GA4 credentials - use ONE of these three options:
# Option 1: Base64-encoded service account JSON (recommended for deployments)
GA4_CREDENTIALS_BASE64=
# Option 2: Raw JSON string
# GA4_CREDENTIALS_JSON=
# Option 3: Path to credentials file
# GA4_CREDENTIALS_PATH=./credentials/ga4-service-account.json

# BigQuery (optional - for detailed event analysis)
# Uses same credentials as GA4
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET=analytics_123456789

# Web Analytics Stream IDs — comma-separated (filters to production website traffic only)
# Get these from GA4 > Admin > Data Streams > Web > Stream ID
# Defaults to "web_prod" stream, excluding "web_dev"
WEB_STREAM_IDS=14050038536

# Firebase (optional - for real-time live monitoring)
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_RTDB_PATH=recordings_live

# Firebase credentials - use ONE of these three options:
# Option 1: Base64-encoded service account JSON (recommended for deployments)
FIREBASE_CREDENTIALS_BASE64=
# Option 2: Raw JSON string
# FIREBASE_CREDENTIALS_JSON=
# Option 3: Path to credentials file
# FIREBASE_CREDENTIALS_PATH=./credentials/firebase-service-account.json